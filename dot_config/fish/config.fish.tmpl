# ──────────────────────────────────────────────────────────────────────────
# ~/.config/fish/config.fish
# Managed by chezmoi: github.com/epoch-chrono/dotfiles
# ──────────────────────────────────────────────────────────────────────────
# Entry point do Fish — mantido estritamente minimal.
#
# Filosofia: tudo user-controlled (env vars, functions, aliases, integrations)
# vive em ~/.dotfiles/ seguindo a taxonomia v1 (ver docs/TAXONOMY.md). O
# config.fish faz UMA coisa: source dos fragments em ~/.dotfiles/ por raiz
# de escopo (personal e professional).
#
# Arquivos gerados automaticamente por tools (brew vendor, fisher plugins,
# `op plugin init`, etc.) podem aparecer em ~/.config/fish/conf.d/ — esses
# são carregados pelo próprio Fish ANTES deste arquivo, sem necessidade de
# intervenção aqui.
# ──────────────────────────────────────────────────────────────────────────


# ── 1. Bloco default do Fish (raramente usado) ────────────────────────────
# Mantido por convenção do template inicial do Fish. Comandos colocados
# aqui rodam SÓ em shells interativos (não em scripts, cron, etc.).

if status is-interactive
    # Commands to run in interactive sessions can go here
end


# ── 2. Loader de fragments user-controlled em ~/.dotfiles/ ────────────────
# Estrutura esperada (ver docs/TAXONOMY.md):
#   ~/.dotfiles/000-personal.d/      — configs pessoais
#   ~/.dotfiles/100-professional.d/  — configs por cliente (recursive)
#
# Filenames seguem lifecycle pattern: <NN><L>-<contexto>.<shell>
# Ex: 10a-environment.fish, 20a-functions.fish, 30a-aliases.fish, ...
#
# `find ... -iname '*.fish' | sort` garante ordem determinística por
# filename — letras `a`/`b`/`c` no sufixo controlam ordem de carregamento
# por shell quando o user mantém triplo .bash/.fish/.zsh no mesmo dir.

if test -d $HOME/.dotfiles/000-personal.d
    for file in (find $HOME/.dotfiles/000-personal.d -type f -iname '*.fish' | sort)
        source "$file"
    end
end

if test -d $HOME/.dotfiles/100-professional.d
    for file in (find $HOME/.dotfiles/100-professional.d -type f -iname '*.fish' | sort)
        source "$file"
    end
end
