java = "lts"
go = "1.26.3"
rust = "1.95.0"
ruby = "3.4.9"
elixir = "1.19.5-otp-28"
erlang = "28.5"
perl = "5.42.2"


# ── Backends prerequisites ────────────────────────────────────────────────
