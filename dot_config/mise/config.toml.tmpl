{{/*
  ─────────────────────────────────────────────────────────────────────
  dot_config/mise/config.toml.tmpl — user-level mise config
  Materializa em ~/.config/mise/config.toml via `chezmoi apply`.

  Distinto do mise.toml na raiz do repo (que declara tools pra dev no
  PRÓPRIO repositório). Este é o config GLOBAL do user, com toolchains
  pra desenvolvimento geral em qualquer projeto.

  Resolução de tools por escopo (mise lê tudo que encontra):
    1. ./mise.toml ou ./.mise.toml do projeto (override local)
    2. ~/.config/mise/config.toml (este aqui — global)
*/}}

[settings]
# Habilita backends/features experimentais (npm:, pipx:, cargo:, ubi:,
# go-install:, aqua:, etc.) e features em beta. Necessário pra plugins
# fora do core sem precisar flag por comando.
experimental = true

# Lockfile: mise.lock versionado no repo. Permite pin de versões mesmo
# usando "latest" / "lts" no config — instala SEMPRE a mesma versão exata
# até que tu rode `mise upgrade` deliberadamente. Reprodutibilidade entre
# máquinas. Gerar/atualizar com: `touch ~/.config/mise/mise.lock && mise install`.
lockfile = true

# Quais plataformas o lockfile cobre. Mac M2 + Linux x64 (pra Docker/dev
# container futuro). Default cobre todas — restringir mantém o lockfile
# menor e mise install mais rápido. Adicionar plataformas quando precisar.
lockfile_platforms = ["macos-arm64", "linux-x64"]

# Cache encrypted (session-scoped) do env+PATH calculados em disco.
# Acelera muito invocações aninhadas (mise x -- mise env, etc.) e shells
# interativos com `mise activate`. Invalidado automaticamente quando
# config muda, tool muda, mise versão muda, ou TTL expira.
env_cache = true

# Supply-chain hygiene: ignora releases publicadas há menos de 7 dias —
# janela pra comunidade detectar releases comprometidos (ataques tipo
# event-stream/eslint-scope/colors.js). Afeta APENAS resolução de
# "latest"/fuzzy versions. Versões pinadas explicitamente (ex.: "3.13.11")
# NÃO são filtradas. Suporta sufixos: 7d, 30d, 6m, 1y, ou data ISO.
minimum_release_age = "7d"

# Não auto-instala tool quando comando não é encontrado. Default true tenta
# instalar a versão "missing" se já tem outra versão da mesma tool. Pra um
# setup declarativo (tudo no config.toml), desativar reduz "magic" no shell:
# se um tool não existe, ele não vai aparecer "do nada" — força a entrada
# explícita no config.
not_found_auto_install = false

# Privacy: opt-out da telemetria anônima do mise-versions.jdx.dev.
# Default true envia (tool@version + OS/arch + IP hashed). Sem impacto
# funcional desabilitar — apenas a tabela de popularidade no host pública
# não conta nossos installs.
use_versions_host_track = false

# Quando descomentado, mise respeita arquivos idiomáticos por projeto
# (.nvmrc, .node-version, package.json devEngines.runtime). Desabilitado
# por enquanto pra não conflitar com setup atual; ativar quando quiser.
# idiomatic_version_file_enable_tools = ["node"]

# NOTA: [settings.github] e [settings.gitlab] credential_command com op REMOVIDOS.
# Motivo: mise hook-env (chamado em CADA prompt do shell, parte do
# mise activate) tenta resolver tokens e dispara o comando configurado.
# Se op não está autenticado (1P.app não signed-in, ex.: SSH non-
# interactive), o prompt "No accounts configured for use with 1Password
# CLI" aparece em todo command prompt — UX inaceitável.
# Estratégia atual: GITHUB_API_TOKEN e GITLAB_TOKEN passados via env var
# ao bootstrap (ver bootstrap.sh + ansible/roles/chezmoi/tasks/main.yml).
# Mise pega direto via env, sem precisar resolver de fonte externa.


[settings.python]
# Integração com projetos uv: ao entrar em diretório com uv.lock, mise
# cria .venv (se não existe) e source na sessão automaticamente. Sem
# isso, precisa source manual ou prefixar tudo com `uv run`.
# Opções:
#   false           — desabilita integração (default)
#   "source"        — só source se .venv existe
#   "create|source" — cria se necessário + source (recomendado)
#   true            — legacy: create|source + export UV_PYTHON
uv_venv_auto = "create|source"


[env]
# ── Default packages files: desabilitados explicitamente ──────────────────
# Setando "" via env var, mise não tenta ler arquivos
# ~/.default-{go,node,python,ruby}-packages. Toda gestão de CLIs/tools
# vai pelos backends declarativos do [tools] abaixo (go:, npm:, pipx:,
# aqua:, etc.). Exceção: gcloud usa ~/.default-cloud-sdk-components
# pra componentes específicos do gcloud-sdk (mantido como dotfile).
MISE_GO_DEFAULT_PACKAGES_FILE     = ""
MISE_NODE_DEFAULT_PACKAGES_FILE   = ""
MISE_PYTHON_DEFAULT_PACKAGES_FILE = ""
MISE_RUBY_DEFAULT_PACKAGES_FILE   = ""

# Aube: permite instalar deps "exóticas" (optional deps marcadas por plataforma)
# sem bloquear. Default true bloqueia. Setando false, aube prossegue com
# avisos em vez de fail. Útil quando um pacote npm tem optional deps de
# plataforma (ex.: fsevents só macOS) que poderiam quebrar em CI/Linux.
# DESABILITADO por enquanto — reabilitar se aparecer erro de optional dep
# bloqueando install.
# AUBE_BLOCK_EXOTIC_SUBDEPS = "false"


