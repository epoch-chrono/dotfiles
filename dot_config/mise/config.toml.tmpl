python = ["3.13.11", { version = "2.7.18", env = { PYTHON_BUILD_HOMEBREW_OPENSSL_FORMULA = "openssl@1.1", LDFLAGS = "-L/opt/homebrew/opt/openssl@1.1/lib", CPPFLAGS = "-I/opt/homebrew/opt/openssl@1.1/include", PKG_CONFIG_PATH = "/opt/homebrew/opt/openssl@1.1/lib/pkgconfig" } }]
