{{/*
  ─────────────────────────────────────────────────────────────────────
  dot_config/mise/config.toml.tmpl — user-level mise config
  Materializa em ~/.config/mise/config.toml via `chezmoi apply`.

  Distinto do mise.toml na raiz do repo (que declara tools pra dev no
  PRÓPRIO repositório). Este é o config GLOBAL do user, com toolchains
  pra desenvolvimento geral em qualquer projeto.

  Resolução de tools por escopo (mise lê tudo que encontra):
    1. ./mise.toml ou ./.mise.toml do projeto (override local)
    2. ~/.config/mise/config.toml (este aqui — global)
*/}}

[settings]
# Habilita backends/features experimentais (npm:, pipx:, cargo:, ubi:,
# go-install:, aqua:, etc.) e features em beta. Necessário pra plugins
# fora do core sem precisar flag por comando.
experimental = true

# Quando descomentado, mise respeita arquivos idiomáticos por projeto
# (.nvmrc, .node-version, package.json devEngines.runtime). Desabilitado
# por enquanto pra não conflitar com setup atual; ativar quando quiser.
# idiomatic_version_file_enable_tools = ["node"]


[settings.github]
# Resolve GitHub PAT via 1Password CLI quando mise precisar fazer chamadas
# à GitHub API (listar releases, baixar artifacts de backends github:, ubi:,
# aqua:, etc.). Sem token: requests anônimas batem rate limit (60/h por IP)
# e quebram `mise install` no meio. Com token autenticado: 5000+ req/h.
#
# Pré-requisitos no Mac:
#   1. 1Password CLI (`op`) instalado e autenticado.
#      Geralmente: app 1Password.app aberto e signed-in, com integração
#      CLI habilitada em Settings → Developer → "Integrate with 1Password CLI".
#      Touch ID resolve o prompt automaticamente.
#   2. Item armazenado no vault dedicado:
#        vault: 00-personal/01-chezmoi (UUID niarnlvrteesurkbocpta7it4e)
#        item:  api-key/github.com/vitor@epoch-chrono.com/chezmoi-bootstrap
#               (UUID 42o44tr7k2rxvmb2a44ee24xcy)
#        field: credential (concealed → precisa --reveal)
#
# Como funciona em runtime:
#   - Mise executa o comando abaixo com mise shims removidos do PATH
#     (evita recursão se op ou qualquer dep vier via mise).
#   - Captura stdout, usa como Bearer token nas chamadas à GitHub API.
#   - Token cached per host per session — chamadas subsequentes na mesma
#     sessão não disparam `op` de novo.
#   - Se `op` falhar (não autenticado, item removido, etc.), mise reverte
#     pra unauthenticated. Não quebra; só fica sujeito a rate limit baixo.
#
# Segurança:
#   - Token nunca toca disco. Vive só em memória da sessão.
#   - UUIDs do 1P em repo público revelam metadata (existe um vault X e
#     item Y), mas são opacos: sem Master Password + Touch ID, não dão
#     acesso a nada.
credential_command = "op item get '42o44tr7k2rxvmb2a44ee24xcy' --vault 'niarnlvrteesurkbocpta7it4e' --fields credential --reveal"


[tools]

# ── Core languages / runtimes ─────────────────────────────────────────────
# Pinned por reprodutibilidade — versões impactantes que mudam APIs.
python = "3.13.11"
node = "lts"
java = "lts"
go = "1.26.3"
rust = "1.95.0"
ruby = "3.4.9"
elixir = "1.19.5-otp-28"
erlang = "28.5"
perl = "5.42.2"
sqlite = "3.53.1"


# ── Backends prerequisites ────────────────────────────────────────────────
# Tools que o mise usa internamente como backend pra outros plugins.
aqua = "latest"   # package-manager declarativo (mise usa como backend aqua:)
uv = "latest"    # python package installer (mise usa como backend pipx:)
aube = "latest"  # Node package manager (mise usa como backend npm:)

# Backend usage examples (descomentar quando precisar):
# "aqua:BurntSushi/ripgrep" = "latest"
# "cargo:eza" = "latest"
# "gem:rubocop" = "latest"
# "github:BurntSushi/ripgrep" = "latest"
# "gitlab:gitlab-org/gitlab-runner" = "latest"
# "go:github.com/DarthSim/hivemind" = "latest"
# "http:my-tool" = { version = "1.0.0", url = "https://example.com/releases/my-tool-v{{ "{{version}}" }}.tar.gz" }


# ── Outros pre-requisites ─────────────────────────────────────────────────
usage = "latest"  # spec-driven CLI framework; mise usa pra completions


