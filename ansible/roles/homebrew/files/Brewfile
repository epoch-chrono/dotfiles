# ── DB clients CLI (client-only, sem servidor) ────────────────────────────
# Alternativa intencional pro mise install mysql/postgres, que instalariam
# o pacote completo (server + client). Aqui pegamos só os binários cliente
# (psql, mysql, mysqldump, pg_dump, pg_restore, mongo, etc.) sem daemons
# nem dependências de runtime de servidor — ~50 MB total vs centenas pelo
# mise full install.

brew "mysql-client"       # cliente MySQL (mysql, mysqldump, mysqladmin)
brew "libpq"              # cliente PostgreSQL (psql, pg_dump, pg_restore)


# ── Formulas dos taps externos ────────────────────────────────────────────
# Cada uma vinculada a um tap declarado acima.

# Não há alternativa via mise; binário antigo mas estável.
brew "sshpass"

# Granted — voltou pro brew porque aqua/mise não suporta darwin/arm64.
# Ver comentário do tap fwdcloudsec/granted acima pra contexto completo.
# gdeploy fica de fora por padrão — adicionar se ainda usado:
# brew "fwdcloudsec/granted/gdeploy"
brew "fwdcloudsec/granted/granted"

# Cloudquery CLI.
brew "cloudquery/tap/cloudquery"

# Powerpipe CLI.
brew "turbot/tap/powerpipe"


