brew "tailscale"          # mesh VPN WireGuard — formula CLI; cask "tailscale-app" falha em
                          # macOS Tahoe (issue tailscale/tailscale#17891 — PKG installer +
                          # System Extension órfã). Daemon roda via:
                          #   sudo brew services start tailscale
                          #   sudo tailscale up
                          # Sem GUI/menu bar app — operação via CLI (status / login / etc.)


