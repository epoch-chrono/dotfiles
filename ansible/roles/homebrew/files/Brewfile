# ── Fontes ────────────────────────────────────────────────────────────────
# Tap experimental epoch-chrono/fonts hospeda Input Mono Nerd Font, que
# NÃO está disponível nos releases oficiais de Nerd Fonts (removida por
# questões de licença OFL — Reserved Font Name "Input"). Tap renomeia
# pra "InputMono Nerd Font" (compliance).
#
# Repo: github.com/epoch-chrono/homebrew-fonts
tap "epoch-chrono/fonts"

# Primária — Input Mono patcheada com Nerd Fonts 3.4.0 (11,313 codepoints).
# Variants: só Regular por enquanto. Bold/Italic dependem de patcheamento
# individual quando o user gerar.
cask "font-input-mono-nerd-font"

# Fallback / segunda opção — Fira Code NFP (cobertura completa, ligatures
# preservadas). Útil quando Input Mono não tem Bold/Italic ainda.
cask "font-fira-code-nerd-font"

# Vanilla Input Mono (sem Nerd glyphs) — não usado, comentado:
# cask "font-input"


# ===========================================================================
# MAS — Apps da Mac App Store
# ===========================================================================
# Apps MAS NÃO ficam aqui no Brewfile — gerenciados via task Ansible com
# o módulo `community.general.mas`. Razões:
#   1. `brew bundle` chama mas-cli em contexto SSH non-interactive durante
#      o bootstrap, e mas-cli falha intermitentemente nesse contexto.
#   2. O módulo Ansible suporta state: present/absent/latest, loop nativo
#      por lista de IDs, check_mode, become: true explícito pra uninstall.
#   3. Falhas individuais não derrubam o bootstrap inteiro (failed_when
#      permissivo na task).
#
# Lista declarada em: ansible/roles/homebrew/defaults/main.yml
# Task de install: ansible/roles/homebrew/tasks/packages.yml
