# ── AWS / cloud tools ─────────────────────────────────────────────────────
# AWS CLI core vem via mise (`awscli` no config.toml.tmpl). Plugins do AWS
# CLI (que são binários separados invocados pelo aws CLI) vêm via brew
# cask quando há cask oficial — manter package management unificado.
#
# session-manager-plugin: binário invocado por `aws ssm start-session` pra
# conectar em EC2 via SSM (Sebastião bastion, instâncias privadas, etc).
# Distribuído pela AWS como .pkg signed installer. Cask oficial do brew
# faz o install do .pkg em /usr/local/sessionmanagerplugin/ + symlink em
# /usr/local/bin/session-manager-plugin. Verificar com:
#   session-manager-plugin --version
#   aws ssm start-session --target i-XXXXX --profile YYY
cask "session-manager-plugin"  # plugin SSM Session Manager pro AWS CLI


# ── AI / coding agents ────────────────────────────────────────────────────
# Tools de coding agents centralizadas no brew (centralizamos aqui em vez
# de mise porque brew distribui binários signed/notarized direto da fonte,
# sem precisar passar pelo backend npm: do mise — menos camadas e melhor
# integração macOS/Tahoe). Updates via `brew upgrade --cask` (incluso na
# task `brew upgrade --cask --greedy` do playbook).
#
# Note: cada agent tem subscrição/auth própria. cursor-cli requer Cursor
# subscription; claude-code requer Anthropic account (Claude Pro/Max/
# Console/etc); gemini-cli usa Google account ou GEMINI_API_KEY.
# brew "gemini-cli"            # https://github.com/google-gemini/gemini-cli (formula)  # substituido por antigravity-cli
cask "antigravity"             # https://antigravity.google/product/antigravity-2
cask "antigravity-cli"         # https://antigravity.google/product/antigravity-cli
cask "antigravity-ide"         # https://antigravity.google/product/antigravity-ide
cask "claude-code"             # stable channel (~1 semana atrás, skip regressions majores)
cask "cursor-cli"              # command-line agent for Cursor

# Alternativas de channel pro claude-code (não usadas — comentadas pra ref):
# cask "claude-code@latest"    # latest channel (versão mais recente disponível)


