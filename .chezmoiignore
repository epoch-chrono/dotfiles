# ──────────────────────────────────────────────────────────────────────────
# .chezmoiignore — paths que o chezmoi NÃO deve materializar em $HOME
# ──────────────────────────────────────────────────────────────────────────
# Este arquivo é processado pelo Go template engine ANTES do chezmoi
# interpretar como ignore-list. Por isso, `#` aqui NÃO é comentário pro
# parser de template — é caractere literal. Cuidado ao escrever
# pseudo-código com sintaxe template entre `#`: vai disparar o parser.
#
# Linhas condicionais por OS/distro são escritas com blocos Go template
# (if/else/end), conforme os blocos mais abaixo neste arquivo.
#
# Apenas paths sob a raiz do repo são considerados. Arquivos/dirs que NÃO
# começam com `dot_`, `private_`, `executable_`, `run_*`, `.chezmoi*` são
# ignorados por padrão (chezmoi só toca em arquivos que ele entende como
# templates dotfile). Mas listar explicitamente aqui:
#   1. Documenta a intenção (futuro leitor entende o layout)
#   2. Garante que `chezmoi apply --verbose` não menciona esses paths
# ──────────────────────────────────────────────────────────────────────────


# ── Repo scaffolding (não é dotfile do user) ──────────────────────────────
README.md
LICENSE
Makefile
mise.toml
bootstrap.sh
.pre-commit-config.yaml
.gitleaks.toml
.editorconfig
docs/
hooks/
ansible/


# ── macOS-only configs — ignorados no Linux ───────────────────────────────
{{ if ne .chezmoi.os "darwin" }}
dot_cursor/
Library/
run_onchange_after_install-crontab.sh.tmpl
run_onchange_after_install-launchagent-path.sh.tmpl
{{ end }}


# ── Linux-only configs — ignorados no macOS ───────────────────────────────
{{ if ne .chezmoi.os "linux" }}
# (reservado pra futuros configs linux-specific)
{{ end }}


# ── NixOS: skip de scripts de bootstrap (nix gerencia deps) ───────────────
{{ if .is_nixos }}
run_once_before_00-install-deps.sh.tmpl
{{ end }}
