#!/usr/bin/env bash
# ────────────────────────────────────────────────────────────────────────────
# run_onchange_after_50-mise-install.sh.tmpl
# ────────────────────────────────────────────────────────────────────────────
# Hook do chezmoi: executa APÓS `chezmoi apply` se o conteúdo deste script
# (incluindo a expansão das variáveis template) mudou desde a última
# execução. Chezmoi guarda o hash do conteúdo expandido e compara.
#
# Prefixo do nome:
#   run_onchange  → roda apenas em mudança de conteúdo (idempotente, não
#                   roda toda vez que apply é chamado)
#   _after_       → roda DEPOIS dos arquivos serem aplicados
#                   (precisa do config.toml já materializado em $HOME)
#   _50-          → ordem entre múltiplos run_onchange (00-99); 50 é meio
#                   pra deixar margem em ambos os lados pra hooks futuros
#
# Como o trigger funciona:
#   O bloco abaixo com hash do config.toml.tmpl força reexecução quando
#   o template muda. Sem isso, chezmoi não saberia que precisa rodar
#   `mise install` depois de você adicionar tools.
# ────────────────────────────────────────────────────────────────────────────

# Trigger hash: muda quando o config.toml.tmpl muda, força re-run deste hook.
# config.toml hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

set -euo pipefail

config_path="$HOME/.config/mise/config.toml"

# Pré-condições
if ! command -v mise >/dev/null 2>&1; then
    echo "[mise-install] mise não encontrado no PATH — skipping."
    echo "[mise-install] Instale via Homebrew (no Brewfile já tem) e re-rode chezmoi apply."
    exit 0
fi

if [ ! -f "$config_path" ]; then
    echo "[mise-install] $config_path não existe — chezmoi apply deveria ter criado."
    echo "[mise-install] Rode 'chezmoi apply' primeiro e tente novamente."
    exit 1
fi

# Trust automático do config — sem isso mise pergunta interativamente
# em cada uso, o que quebra automation. Comando idempotente.
mise trust "$config_path" >/dev/null

# Instalar tools declaradas no config (idempotente — não reinstala o que já tem)
echo "[mise-install] Aplicando tools de $config_path..."
mise install

echo "[mise-install] OK — tools sincronizadas com $config_path."
